generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//==================== PERMISSION MODEL ======================
model Permission {
  id               String            @id @default(uuid())
  permission       String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  staffPermissions StaffPermission[]
}

//============= ROLE PERMISSION INTERMIDIATE MODEL ============
model StaffPermission {
  id           String     @id @default(uuid())
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  staffType    StaffType? @relation(fields: [staffTypeId], references: [id], onDelete: Cascade)
  staffTypeId  String?

  @@unique([staffTypeId, permissionId])
}

//============= USER MODEL ============
enum USER_ROLE {
  SUPER_ADMIN
  ADMIN
  STAFF
  PESSENGER
}

enum USER_STATUS {
  ACTIVE
  INACTIVE
  BLOCK
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  phone      String      @unique
  password   String
  role       USER_ROLE   @default(PESSENGER)
  isDeleted  Boolean     @default(false)
  status     USER_STATUS @default(INACTIVE)
  isVerified Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  admin      Admin?
  staff      Staff?
}

//============= ADMIN MODEL ============//
model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  avatar      String?
  user        User     @relation(fields: [userId], references: [id])
  joiningDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

//================== STATION INFORMATION MODEL ================
model Station {
  id                    String     @id @default(uuid())
  stationId             String     @unique
  phone                 String     @unique
  email                 String     @unique
  type                  String
  division              String
  district              String
  name                  String
  status                String     @default("Active")
  establishedYear       Int?
  notes                 String?
  ticketCounter         Boolean    @default(false)
  onlineTicketSupport   Boolean    @default(false)
  foodCourt             Boolean    @default(false)
  parking               Boolean    @default(false)
  hasDisplayBoard       Boolean    @default(false)
  hasAnnouncementSystem Boolean    @default(false)
  wheelchairAccess      Boolean    @default(false)
  wifi                  Boolean    @default(false)
  washroom              Boolean    @default(false)
  atm                   Boolean    @default(false)
  securityService       Boolean    @default(false)
  cctv                  Boolean    @default(false)
  prayerRoom            Boolean    @default(false)
  escalator             Boolean    @default(false)
  lift                  Boolean    @default(false)
  platforms             Platform[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  staffs                Staff[]

  @@map("stations")
}

model Platform {
  id String @id @default(uuid())

  stationId String
  station   Station  @relation(fields: [stationId], references: [stationId], onDelete: Cascade)
  name      String
  type      String
  status    String   @default("Active")
  length    Int
  capacity  Int
  hasRoof   Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platforms")
}

// ================ STAFF MODEL =====================
enum ShiftType {
  MORNING
  EVENING
  NIGHT
}

