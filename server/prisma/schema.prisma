// ============= ROUTE ======================
model Route {
  id   String @id @default(ulid())
  name String

  sourceStationId String
  sourceStation   Station @relation("RouteSource", fields: [sourceStationId], references: [stationId])

  destinationStationId String
  destinationStation   Station @relation("RouteDestination", fields: [destinationStationId], references: [stationId])

  distance Float?

  routeStations RouteStation[]

  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("routes")
}

//=================== ROUTE STATION======================
model RouteStation {
  id String @id @default(ulid())

  routeId String
  route   Route  @relation(fields: [routeId], references: [id])

  stationId String
  station   Station @relation(fields: [stationId], references: [stationId])

  sequence             Int
  distanceFromStart    Float?
  distanceFromPrevious Float?

  // ===== সময় =====
  travelTimeFromPrevious Int?
  stopTime               Int     @default(2)
  isMajorStop            Boolean @default(true)
  platform               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([routeId, sequence])
  @@unique([routeId, stationId])
  @@map("route_stations")
}

// ================ SCHEDULE =======================
enum Direction {
  UP
  DOWN
}

enum TripStatus {
  SCHEDULED
  RUNNING
  COMPLETED
  CANCELLED
  DELAYED
}

// ============ SCHEDULE (Master/Template) ============
model Schedule {
  id              String         @id @default(ulid())
  trainId         String
  train           Train          @relation(fields: [trainId], references: [id])
  routeId         String
  route           Route          @relation(fields: [routeId], references: [id])
  direction       Direction
  name            String?
  startTime       String
  runningDays     Json
  bookingOpenDays Int
  validFrom       DateTime
  validUntil      DateTime?
  isActive        Boolean        @default(true)
  tripInstances   TripInstance[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("schedules")
}

// ============ TRIP INSTANCE (একদিনের নির্দিষ্ট যাত্রা) ============
model TripInstance {
  id             String     @id @default(ulid())
  scheduleId     String
  schedule       Schedule   @relation(fields: [scheduleId], references: [id])
  journeyDate    DateTime
  status         TripStatus @default(SCHEDULED)
  remarks        String?
  totalSeats     Int?
  availableSeats Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([scheduleId, journeyDate])
  @@map("trip_instances")
}

// ================ STAFF MODEL =====================
enum ShiftType {
  MORNING
  EVENING
  NIGHT
}

